{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"],
      "./client/src/i18n/config": ["./client/src/i18n/config.node.ts"],
      "@/i18n/config": ["./client/src/i18n/config.node.ts"],
      "./i18n/config": ["./client/src/i18n/config.node.ts"]
    },
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "scripts/**/*"
  ]
}
